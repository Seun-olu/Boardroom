NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# New keys (recommended) — Settings → API Keys → "Publishable and secret API keys"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Legacy JWT keys still work — Settings → API Keys → "Legacy anon, service_role"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← must say service_role inside, NOT anon
